    "better-sqlite3": "^9.2.2",
    "joi": "^17.11.0",
    "semver": "^7.5.4",
    "uuid": "^9.0.1",
    "multer": "^1.4.5-lts.1",
    "tar": "^6.2.0",
    "sanitize-filename": "^1.6.3"
