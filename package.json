{
  "name": "atlasia-ghost",
  "version": "1.1.2",
  "description": "Zero-Trust Git governance CLI: verify commits, enforce policy gates, and run sandboxed extensions (sovereign alternative to Husky/Commitlint).",
  "scripts": {
    "start": "node ghost.js",
    "test": "node test.js",
    "test:smoke": "node scripts/test/smoke-help.mjs",
    "test:default": "node scripts/test/smoke-default-help.mjs",
    "test:safe": "node scripts/test/smoke-safe-mode.mjs",
    "test:pack": "node scripts/test/pack-contents.mjs",
    "test:all": "node scripts/test/smoke-help.mjs && node scripts/test/smoke-default-help.mjs && node scripts/test/smoke-safe-mode.mjs && node scripts/test/pack-contents.mjs",
    "console": "node ghost.js console start"
  },
  "main": "ghost.js",
  "bin": {
    "ghost": "ghost.js"
  },
  "author": "Adel Lamallam",
  "license": "MIT",
  "homepage": "https://github.com/lamallamadel/ghost#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lamallamadel/ghost.git"
  },
  "bugs": {
    "url": "https://github.com/lamallamadel/ghost/issues"
  },
  "keywords": [
    "git",
    "commit",
    "conventional-commits",
    "commitlint",
    "husky",
    "hooks",
    "pre-commit",
    "ci",
    "policy",
    "policy-as-code",
    "governance",
    "zero-trust",
    "security",
    "sandbox",
    "sandboxed-extensions",
    "extensions",
    "marketplace",
    "ai",
    "ai-orchestrator",
    "nist",
    "si-10",
    "supply-chain",
    "devsecops",
    "sovereign-ai"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "ghost.js",
    "core/",
    "lib/",
    "extensions/",
    "packages/extension-sdk/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "jsonwebtoken": "^9.0.3",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
