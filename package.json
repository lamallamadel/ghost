{
  "name": "atlasia-ghost",
  "version": "0.4.0",
  "description": "Extensible gateway-based Git CLI with AI-powered operations",
  "main": "ghost.js",
  "files": [
    "ghost.js",
    "core/**/*.js",
    "core/**/*.json",
    "extensions/ghost-git-extension/**",
