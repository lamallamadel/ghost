{
  "id": "ghost-cli-extension",
  "name": "Ghost Interactive Shell",
  "version": "2.0.0",
  "main": "index.js",
  "description": "Beautiful interactive shell with command palette, fuzzy autocomplete, history, and smart NL routing",
  "commands": ["start"],
  "capabilities": {
    "filesystem": {
      "read":  ["~/.ghost/cli-history.json", "~/.ghost/config/ghostrc.json"],
      "write": ["~/.ghost/cli-history.json"]
    },
    "git": {
      "read": true
    },
    "system": {
      "registry": true
    },
    "extension": {
      "call": true
    }
  },
  "permissions": [
    "filesystem:read",
    "filesystem:write",
    "git:read",
    "system:registry",
    "extension:call"
  ]
}
