{
  "id": "ghost-desktop-extension",
  "name": "Ghost Desktop Console",
  "version": "1.0.0",
  "description": "Desktop UI and real-time telemetry console for Ghost CLI.",
  "main": "index.js",
  "commands": ["start", "stop", "status"],
  "capabilities": {
    "network": {
      "mesh": true
    },
    "process": {
      "spawn": true
    }
  },
  "permissions": [
    "filesystem:read",
    "network:mesh",
    "network:https",
    "process:spawn"
  ]
}
