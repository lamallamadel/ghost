{
  "id": "ghost-system-extension",
  "name": "Ghost System Helper",
  "version": "1.0.0",
  "description": "System monitoring and environment health management.",
  "main": "index.js",
  "commands": ["status", "logs", "sanitize", "doctor", "env"],
  "capabilities": {
    "filesystem": {
      "read": [
        "~/.ghost/audit.log",
        "~/.ghost/config/*",
        "~/.ghost/marketplace-cache/*"
      ],
      "write": [
        "~/.ghost/audit.log*",
        "~/.ghost/temp/*",
        "~/.ghost/config/ghostrc.json"
      ]
    }
  },
  "permissions": [
    "filesystem:read",
    "filesystem:write",
    "process:spawn"
  ]
}
