{
  "id": "ghost-git-extension",
  "name": "Ghost Git Extension",
  "version": "1.0.0",
  "description": "Git operations extension for Ghost CLI with AI-powered commit generation, security scanning, version management, and merge resolution",
  "main": "index.js",
  "capabilities": {
    "filesystem": {
      "read": ["**/*"],
      "write": [".git/**", "package.json", ".ghost-versionrc", ".ghostignore", ".ghostrc", "~/.ghost*"]
    },
    "network": {
      "allowlist": [
        "https://api.groq.com",
        "https://api.openai.com",
        "https://api.anthropic.com",
        "https://generativelanguage.googleapis.com"
      ],
      "rateLimit": {
        "cir": 100000,
        "bc": 500000
      }
    },
    "git": {
      "read": true,
      "write": true
    },
    "hooks": ["pre-commit", "commit-msg", "pre-push"]
  }
}
