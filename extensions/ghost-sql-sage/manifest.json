{
  "id": "ghost-sql-sage",
  "name": "Ghost SQL-Sage",
  "version": "1.0.0",
  "description": "Database query optimization and schema auditing engine.",
  "main": "index.js",
  "commands": ["analyze", "audit", "generate"],
  "capabilities": {
    "filesystem": {
      "read": ["**/*.js", "**/*.ts", "**/*.sql", "**/migrations/*.js"],
      "write": ["**/sql-optimizations/*.md", "**/migrations/*.sql"]
    },
    "network": {
      "allowlist": [
        "https://api.groq.com",
        "https://api.openai.com",
        "https://api.anthropic.com",
        "https://generativelanguage.googleapis.com"
      ]
    }
  },
  "permissions": [
    "filesystem:read",
    "filesystem:write",
    "network:https"
  ]
}
