{
  "name": "atlasia-ghost",
  "version": "0.4.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "atlasia-ghost",
      "version": "0.4.0",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "bin": {
        "ghost": "ghost.js"
      },
      "engines": {
        "node": ">=14.0.0"
      }
    },
    "node_modules/@ghost/extension-sdk": {
      "resolved": "packages/extension-sdk",
      "link": true
    },
    "packages/extension-sdk": {
      "name": "@ghost/extension-sdk",
      "version": "1.0.0",
      "license": "MIT",
      "engines": {
        "node": ">=14.0.0"
      }
    }
  }
}
